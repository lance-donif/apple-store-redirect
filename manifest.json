{
  "manifest_version": 3,
  "name": "Apple Store Redirect Guard",
  "version": "1.2.2",
  "description": "Blocks Apple Store's client-side fallback to the China Today page.",
  "permissions": ["cookies", "declarativeNetRequest", "webNavigation", "browsingData"],
  "host_permissions": ["https://apps.apple.com/*", "https://fanqienovel.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://apps.apple.com/*"],
      "js": ["state.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://apps.apple.com/*"],
      "js": ["guard.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://fanqienovel.com/reader/*"],
      "js": ["fanqie-copy.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Apple Store Redirect Guard"
  }
}
